# Worker env example
NODE_ENV="worker"

# Supabase
SUPABASE_URL=""
SUPABASE_SECRET_KEY=""
SUPABASE_SCHEMA="public"

# Optional cache
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
CACHE_KEY_PREFIX="nba:serve"

# Optional overrides
WORKER_MODE="cron"
CRON_MIN_INTERVAL_MS=60000
CRON_WINDOW_START_HOUR=15
CRON_WINDOW_END_HOUR=1
CRON_IN_WINDOW_MIN_INTERVAL_MS=900000
CRON_IN_WINDOW_MAX_INTERVAL_MS=1800000
CRON_OFF_WINDOW_INTERVAL_MS=10800000
CRON_LIVE_BOXSCORE_LOOKBACK_DAYS=2
CRON_LIVE_BOXSCORE_INTERVAL_MS=900000
CRON_OFF_WINDOW_LIVE_BOXSCORE_INTERVAL_MS=10800000
CRON_LIVE_GAMES_LOOKBACK_DAYS=3
CRON_LIVE_GAMES_INTERVAL_MS=900000
CRON_OFF_WINDOW_LIVE_GAMES_INTERVAL_MS=10800000
CRON_MAINTENANCE_MIN_REMAINING_MS=600000
CRON_MAX_RUNS_PER_DAY=50
CRON_MAX_RUNTIME_MS=3600000
API_MIN_INTERVAL_MS=1500
API_RETRY_MAX=4
API_RETRY_BASE_DELAY_MS=750
HISTORIC_SEASONS_BACK=2
PLAYERS_HISTORIC_MODE="once"
PLAYERS_HISTORIC_SEASONS_BACK=2
NBA_SEASON="2025-26"
NBA_TIME_ZONE="America/New_York"

# Polling intervals (ms)
LIVE_GAMES_INTERVAL_MS=5000
SCOREBOARD_INTERVAL_MS=10000
TEAMS_INTERVAL_MS=21600000
PLAYERS_INTERVAL_MS=21600000
STANDINGS_INTERVAL_MS=900000
PLAYER_STATS_INTERVAL_MS=21600000
TEAM_STATS_INTERVAL_MS=3600000
STATUS_REFRESH_MS=60000
BOXSCORE_CONCURRENCY=3
UPSERT_CHUNK_SIZE=200
